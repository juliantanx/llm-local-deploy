# LLM Local Deploy - Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Ollama Configuration
# =============================================================================
# Host port for Ollama API (default: 11434)
OLLAMA_PORT=11434

# Number of parallel requests Ollama can handle
# OLLAMA_NUM_PARALLEL=4

# Keep models loaded for faster subsequent requests (default: 5m)
# OLLAMA_KEEP_ALIVE=5m

# GPU layers for llama.cpp (set to 0 for CPU-only)
# OLLAMA_GPU_LAYERS=35

# =============================================================================
# Open WebUI Configuration
# =============================================================================
# Host port for WebUI (default: 3000)
WEBUI_PORT=3000

# Secret key for session encryption (generate a secure random string)
WEBUI_SECRET_KEY=

# =============================================================================
# ChromaDB Configuration (RAG)
# =============================================================================
# Host port for ChromaDB (default: 8000)
CHROMA_PORT=8000

# ChromaDB authentication token (generate a secure token for production)
CHROMA_SERVER_AUTH_CREDENTIALS=your-secret-token-here

# =============================================================================
# Model Configuration
# =============================================================================
# Default model to pull on first run (comment out to skip auto-pull)
DEFAULT_MODEL=llama3.2:3b

# =============================================================================
# Storage Paths
# =============================================================================
# Ollama models directory (persisted via volume)
OLLAMA_MODELS_DIR=./data/ollama

# WebUI data directory (persisted via volume)
WEBUI_DATA_DIR=./data/webui

# ChromaDB data directory (persisted via volume)
CHROMA_DATA_DIR=./data/chroma